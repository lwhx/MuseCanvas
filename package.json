{
  "name": "muse-canvas",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --if-present --filter './apps/*' dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:e2e:admin": "node tests/e2e/admin-panel.mjs",
    "prepare:prompt-templates": "node scripts/prepare-prompt-templates.mjs",
    "compose:up": "pnpm prepare:prompt-templates && docker compose up --build -d",
    "compose:down": "docker compose down"
  }
}
