# ──────────────────────────────────────────────────────────────
# MuseCanvas environment template
# Copy to .env and fill in. NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────

# ===== Frontend (apps/web) — only VITE_* vars reach the browser =====
# Base URL the web app calls for the backend API (proxied via Nginx in prod).
VITE_API_BASE_URL=/api

# ===== Backend (apps/api) — server-side only, never exposed to browser =====
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://musecanvas:change-me@localhost:5432/musecanvas
REDIS_URL=redis://localhost:6379

# Session cookie signing secret (HttpOnly + Secure + SameSite).
SESSION_SECRET=
ADMIN_EMAIL=admin@example.com
COOKIE_SECURE=false

# ===== SMTP (server-side only) =====
# OTP 邮件只从环境变量读取，不再支持后台运行时修改。
SMTP_HOST=smtp.example.com
SMTP_PORT=465
# one of: implicit_tls, starttls, none
SMTP_TLS_MODE=implicit_tls
SMTP_FROM=no-reply@example.com
SMTP_FROM_NAME=MuseCanvas
SMTP_USER=
SMTP_PASSWORD=

# ===== Object storage (S3-compatible) — server-side only =====
S3_ENDPOINT=https://s3.example.com
S3_PUBLIC_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=musecanvas
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ===== Deployment security policies =====
# This flag is only a deployment-level production safety override.
ALLOW_INSECURE_SMTP=false

# ===== OAuth deployment settings =====
# Provider Client IDs and Client Secrets are configured in the admin console.
OAUTH_REDIRECT_BASE_URL=http://localhost:8080
OAUTH_CREDENTIALS_ENCRYPTION_KEY=

# ===== Provider credential encryption — server-side only =====
# Provider API keys, Base URLs, models, and protocols are configured in the
# admin console. Only the stable encryption master key belongs here.
PROVIDER_CREDENTIALS_ENCRYPTION_KEY=

# Local/private provider endpoints are rejected unless explicitly enabled.
ALLOW_INSECURE_PROVIDER_BASE_URL=false
ALLOW_PRIVATE_PROVIDER_BASE_URL=false

# ===== Prompt templates — API/worker only =====
# Absolute host path to the external index.json. `pnpm compose:up` will sync
# this index and its referenced Markdown templates into a fixed runtime
# directory that Compose mounts read-only into API and Worker.
PROMPT_TEMPLATE_INDEX_PATH=/absolute/path/to/prompt-templates/index.json
