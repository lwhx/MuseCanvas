# ──────────────────────────────────────────────────────────────
# MuseCanvas environment template
# Copy to .env and fill in. NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────

# ===== Frontend (apps/web) — only VITE_* vars reach the browser =====
# Base URL the web app calls for the backend API (proxied via Nginx in prod).
VITE_API_BASE_URL=/api
# When "true", the web app serves data from in-memory mock fixtures
# instead of calling the real backend. Useful for frontend-only dev.
VITE_USE_MOCK=false

# ===== Backend (apps/api) — server-side only, never exposed to browser =====
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://musecanvas:change-me@localhost:5432/musecanvas
REDIS_URL=redis://localhost:6379

# Session cookie signing secret (HttpOnly + Secure + SameSite).
SESSION_SECRET=
SMTP_ENCRYPTION_KEY=
ADMIN_EMAIL=admin@example.com
COOKIE_SECURE=false

# ===== Object storage (S3-compatible) — server-side only =====
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=musecanvas
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ===== SMTP (OTP delivery) — server-side only, managed via admin UI =====
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS_MODE=none
ALLOW_INSECURE_SMTP=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@musecanvas.local

# ===== OAuth — server-side only =====
OAUTH_REDIRECT_BASE_URL=http://localhost:8080
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_CREDENTIALS_ENCRYPTION_KEY=

# ===== Provider credential encryption — server-side only =====
PROVIDER_CREDENTIALS_ENCRYPTION_KEY=
ALLOW_PROVIDER_ENV_FALLBACK=false

# ===== Image generation providers — server/worker only, NEVER in frontend =====
# OpenAI (gpt-image-2)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
# Volcengine / BytePlus ModelArk (Seedream)
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com
# Local/private provider endpoints are rejected unless explicitly enabled.
ALLOW_INSECURE_PROVIDER_BASE_URL=false
ALLOW_PRIVATE_PROVIDER_BASE_URL=false
